@host = http://localhost:3000

############################################################
# AUTH
############################################################

### Register USER (Expected: 201)
POST {{host}}/auth/register
Content-Type: application/json

{
    "username": "alice",
    "password": "secret123"
}

###

### Register another USER
POST {{host}}/auth/register
Content-Type: application/json

{
    "username": "bob",
    "password": "secret123"
}

###

### Duplicate username (Expected: 409)
POST {{host}}/auth/register
Content-Type: application/json

{
    "username": "alice",
    "password": "secret123"
}

###

### Login USER (Expected: 200)
POST {{host}}/auth/login
Content-Type: application/json

{
    "username": "alice",
    "password": "secret123"
}

###

### Wrong password (Expected: 401)
POST {{host}}/auth/login
Content-Type: application/json

{
    "username": "alice",
    "password": "wrongpassword"
}

############################################################
# TOKENS
############################################################

# USER Token
@userToken = PASTE_USER_TOKEN_HERE

# ADMIN Token
@adminToken = PASTE_ADMIN_TOKEN_HERE

############################################################
# UNAUTHORIZED REQUESTS
############################################################

### Get Tasks (401)
GET {{host}}/tasks

###

### Create Task (401)
POST {{host}}/tasks
Content-Type: application/json

{
    "title":"Unauthorized"
}

###

### Delete Task (401)
DELETE {{host}}/tasks/1

############################################################
# USER TASK APIs
############################################################

### Create Task 1
POST {{host}}/tasks
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
    "title":"Learn NestJS"
}

###

### Create Task 2
POST {{host}}/tasks
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
    "title":"Learn PostgreSQL"
}

###

### Get All Tasks
GET {{host}}/tasks
Authorization: Bearer {{userToken}}

###

### Get Task
GET {{host}}/tasks/1
Authorization: Bearer {{userToken}}

###

### Invalid Task
GET {{host}}/tasks/999
Authorization: Bearer {{userToken}}

###

### Update Title
PATCH {{host}}/tasks/1
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
    "title":"Master NestJS"
}

###

### Complete Task
PATCH {{host}}/tasks/1
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
    "completed":true
}

###

### Update Both
PATCH {{host}}/tasks/2
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
    "title":"Updated Task",
    "completed":true
}

############################################################
# USER DELETE (Should Fail)
############################################################

### USER Delete Task (Expected: 403)
DELETE {{host}}/tasks/1
Authorization: Bearer {{userToken}}

############################################################
# ADMIN TASK APIs
############################################################

### ADMIN Get All Tasks
GET {{host}}/tasks
Authorization: Bearer {{adminToken}}

###

### ADMIN Get Any Task
GET {{host}}/tasks/1
Authorization: Bearer {{adminToken}}

###

### ADMIN Delete Task
DELETE {{host}}/tasks/1
Authorization: Bearer {{adminToken}}

###

### ADMIN Delete Invalid Task
DELETE {{host}}/tasks/999
Authorization: Bearer {{adminToken}}

############################################################
# USERS (ADMIN ONLY)
############################################################

### Get All Users
GET {{host}}/users
Authorization: Bearer {{adminToken}}

###

### Get User
GET {{host}}/users/1
Authorization: Bearer {{adminToken}}

###

### Invalid User
GET {{host}}/users/999
Authorization: Bearer {{adminToken}}

############################################################
# CHANGE ROLE
############################################################

### Promote User to ADMIN
PATCH {{host}}/users/2/role
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "role":"ADMIN"
}

###

### Demote ADMIN to USER
PATCH {{host}}/users/2/role
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "role":"USER"
}

############################################################
# DELETE USERS
############################################################

### Delete USER
DELETE {{host}}/users/2
Authorization: Bearer {{adminToken}}

###

### Delete Invalid User
DELETE {{host}}/users/999
Authorization: Bearer {{adminToken}}

############################################################
# RBAC TESTS
############################################################

### USER tries to list users (403)
GET {{host}}/users
Authorization: Bearer {{userToken}}

###

### USER tries to get user by id (403)
GET {{host}}/users/1
Authorization: Bearer {{userToken}}

###

### USER tries to change role (403)
PATCH {{host}}/users/2/role
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
    "role":"ADMIN"
}

###

### USER tries to delete user (403)
DELETE {{host}}/users/2
Authorization: Bearer {{userToken}}

############################################################
# LAST ADMIN SAFEGUARD
############################################################

### Demote Last Admin (Expected: 403)
PATCH {{host}}/users/1/role
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "role":"USER"
}

###

### Delete Last Admin (Expected: 403)
DELETE {{host}}/users/1
Authorization: Bearer {{adminToken}}